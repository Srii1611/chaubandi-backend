# ============================================================
# Chaubandi Medusa v2 Backend - Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================

# --- Database (PostgreSQL 14+) ---
# CHAUBANDI_DATABASE_URL takes precedence over DATABASE_URL (protects
# against a system-level DATABASE_URL env var from another project).
CHAUBANDI_DATABASE_URL=postgresql://user:password@localhost:5432/chaubandi
DATABASE_URL=postgresql://user:password@localhost:5432/chaubandi

# --- Redis (for event subscribers + caching) ---
REDIS_URL=redis://localhost:6379

# --- Medusa Secrets (generate strong random strings for production) ---
JWT_SECRET=super_secret_jwt_string_change_me
COOKIE_SECRET=super_secret_cookie_string_change_me

# --- CORS (adjust to match your storefront URLs) ---
STORE_CORS=http://localhost:5173,http://localhost:3000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000

# --- Stripe Payments ---
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- SendGrid Email ---
# 1) API key from SendGrid  2) FROM must be a *verified* sender/domain
# 3) OWNER_EMAIL is where contact / order / booking notifications are sent.
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=sushma@chaubandi.com
OWNER_EMAIL=sushma@chaubandi.com

# --- Email template IDs (optional) ---
# The SendGrid provider sends via *dynamic templates*: put each template's ID
# here. Leave blank to fall back to the built-in inline HTML (works as-is if
# you switch the provider to Resend, which sends raw HTML). See EMAIL-SETUP.md.
SENDGRID_TEMPLATE_ORDER_CONFIRMATION=
SENDGRID_TEMPLATE_ORDER_ADMIN=
SENDGRID_TEMPLATE_NEWSLETTER_WELCOME=
SENDGRID_TEMPLATE_NEWSLETTER_ADMIN=
SENDGRID_TEMPLATE_CONTACT=
SENDGRID_TEMPLATE_INSPIRATION=
SENDGRID_TEMPLATE_APPOINTMENT=

# --- Google Reviews (live rating + up to 5 featured reviews) ---
# Free within Google Maps Platform's monthly credit. Enable "Places API (New)"
# in Google Cloud, create an API key, and get the Place ID from the boutique's
# Google Business Profile. Leave blank to fall back to curated reviews.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# --- Cloudflare R2 (S3-compatible file storage) ---
# Leave blank to use local file storage for development
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=chaubandi-uploads
R2_PUBLIC_URL=

# --- Appointment Config ---
APPOINTMENT_FEE_CENTS=1000
APPOINTMENT_AVAILABLE_DAYS=5
APPOINTMENT_START_HOUR=10
APPOINTMENT_END_HOUR=18
APPOINTMENT_SLOT_MINUTES=30
