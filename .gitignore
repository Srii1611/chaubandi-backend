# Dependencies
node_modules/
# package-lock.json is committed: deploys use `npm ci`, which needs it and
# fails without a lockfile that matches package.json exactly.
yarn.lock
pnpm-lock.yaml

# Environment variables
.env
.env.local
.env.production

# Build output
.dist/
.medusa/

# Local file-storage output (dev). Leading slash anchors these to the repo
# root so they do NOT match the src/api/store/uploads API route directory.
# The local file provider writes to static/ (see medusa-config.ts upload_dir).
/uploads/
/static/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test coverage
coverage/

# Misc
*.pid
*.seed
*.pid.lock
