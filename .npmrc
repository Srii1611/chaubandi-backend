# Install devDependencies even when NODE_ENV=production.
#
# `medusa build` needs typescript, vite, react and @swc/core to compile the
# backend and build the admin dashboard, and all of them live in
# devDependencies. Hosts that default npm to production mode (Railway's
# Nixpacks among them) strip exactly those packages, so the install succeeds
# and the build then fails on a missing compiler.
#
# The runtime image stays lean regardless: railway.toml installs the built
# server in .medusa/server with --omit=dev.
production=false
